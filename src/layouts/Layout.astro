---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Caio Sousa — Portfólio', description = 'Portfólio de desenvolvedor' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link id="favicon" rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
  <script>
    const fp = document.getElementById('fullpage') as HTMLElement;
    const sections = Array.from(document.querySelectorAll<HTMLElement>('.section'));
    let current = 0;
    let isAnimating = false;

    function goTo(index: number) {
      if (index < 0 || index >= sections.length || isAnimating) return;
      current = index;
      isAnimating = true;
      fp.style.transform = `translateY(-${current * 100}vh)`;
      setTimeout(() => { isAnimating = false; }, 600);
    }

    const BOUNDARY_THRESHOLD = 7000;
    let boundaryAccum = 0;

    window.addEventListener('wheel', (e) => {
      const scrollable = (e.target as Element).closest('.projects-scroll, .skill-list');
      if (scrollable) {
        const atBottom = scrollable.scrollTop + scrollable.clientHeight >= scrollable.scrollHeight - 2;
        const atTop = scrollable.scrollTop <= 2;
        const atBoundary = (e.deltaY > 0 && atBottom) || (e.deltaY < 0 && atTop);

        if (!atBoundary) {
          boundaryAccum = 0;
          return;
        }

        boundaryAccum += Math.abs(e.deltaY);
        e.preventDefault();
        if (boundaryAccum < BOUNDARY_THRESHOLD || isAnimating) return;
        boundaryAccum = 0;
        goTo(current + (e.deltaY > 0 ? 1 : -1));
        return;
      }

      e.preventDefault();
      if (isAnimating) return;
      goTo(current + (e.deltaY > 0 ? 1 : -1));
    }, { passive: false });

    let touchStartY = 0;
    window.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });
    window.addEventListener('touchend', (e) => {
      if (isAnimating) return;
      const delta = touchStartY - e.changedTouches[0].clientY;
      if (Math.abs(delta) < 40) return;
      goTo(current + (delta > 0 ? 1 : -1));
    }, { passive: true });

    window.addEventListener('keydown', (e) => {
      if (isAnimating) return;
      if (['ArrowDown', 'PageDown', ' '].includes(e.key)) { e.preventDefault(); goTo(current + 1); }
      if (['ArrowUp', 'PageUp'].includes(e.key)) { e.preventDefault(); goTo(current - 1); }
    });

    document.addEventListener('click', (e) => {
      const link = (e.target as Element).closest('a[href^="#"]') as HTMLAnchorElement | null;
      if (!link) return;
      e.preventDefault();
      const id = link.getAttribute('href')!.slice(1);
      const idx = sections.findIndex(s => s.id === id);
      if (idx !== -1) goTo(idx);
    });
  </script>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
